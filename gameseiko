<!DOCTYPE html>
<html lang="en">
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eiko Games 👑</title>

<style>
body {
  margin: 0;
  font-family: Arial;
  background: #020617;
  color: white;
}

/* HEADER */
header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px;
  background: #22c55e;
}

#toggle {
  background: white;
  border: none;
  padding: 8px;
  border-radius: 8px;
}

/* SEARCH */
.search {
  text-align: center;
  margin: 15px;
}

.search input {
  width: 80%;
  padding: 10px;
  border-radius: 10px;
  border: none;
}

/* GAME CARD */
.game {
  margin: 15px;
  background: #1e293b;
  border-radius: 15px;
  padding: 10px;
}

/* IFRAME */
iframe {
  width: 100%;
  height: 500px;
  border: none;
  border-radius: 15px;
}

/* DARK MODE */
.dark {
  background: #fff;
  color: black;
}

footer {
  text-align: center;
  padding: 15px;
}
</style>
</head>

<body>

<header>
  <h2>🎮 Eiko Games</h2>
  <button id="toggle">🌙</button>
</header>

<div class="search">
  <input type="text" placeholder="🔍 Search..." onkeyup="searchGame(this.value)">
</div>

<!-- GAMES -->

<div class="game">
  <h3>🚇 Subway Runner</h3>
  <iframe src="https://games.crazygames.com/en_US/subway-surfers/index.html"></iframe>
</div>

<div class="game">
  <h3>⚽ Football Match</h3>
  <iframe src="https://games.crazygames.com/en_US/football-heads-2023/index.html"></iframe>
</div>

<div class="game">
  <h3>⚽ Soccer Skills</h3>
  <iframe src="https://games.crazygames.com/en_US/soccer-skills-euro-cup/index.html"></iframe>
</div>

<div class="game">
  <h3>⚽ Penalty Shootout</h3>
  <iframe src="https://html5games.com/Game/Penalty-Shootout/"></iframe>
</div>

<div class="game">
  <h3>🚗 Racing Game</h3>
  <iframe src="https://html5games.com/Game/Speed-Racer/"></iframe>
</div>

<div class="game">
  <h3>🧠 Puzzle 2048</h3>
  <iframe src="https://html5games.com/Game/2048/"></iframe>
</div>

<footer>
👑 Made by Zakariae - Eiko Games
</footer>

<script>

/* SEARCH */
function searchGame(value){
  let games = document.querySelectorAll(".game");
  games.forEach(game=>{
    let title = game.innerText.toLowerCase();
    game.style.display = title.includes(value.toLowerCase()) ? "block":"none";
  });
}

/* DARK MODE */
document.getElementById("toggle").onclick = () => {
  document.body.classList.toggle("dark");
}

</script>

</body>
</html>
